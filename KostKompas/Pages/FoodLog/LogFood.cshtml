@page "{id:int}"
@model KostKompas.Pages.FoodLog.LogFoodModel
@{
}


<section class="log-food-page">
    <div class="log-food-card">

        <p class="eyebrow">MADLOG</p>
        <h1>Vælg fødevare</h1>
        <p class="log-food-text">
            Søg og vælg en fødevare, og angiv mængden i gram.
        </p>

        <form method="post" class="log-food-form">

            <input type="hidden" asp-for="CurrentMeal.Id" />

            <div class="form-group-custom">
                <label>Fødevare</label>
                <select asp-for="FoodId" class="form-control-custom">
                    @foreach (var food in Model.Foods)
                    {
                        <option value="@food.Id">@food.Name</option>
                    }
                </select>
            </div>

            <div class="form-group-custom">
                <label>Gram</label>
                <input asp-for="WeightInGramsInput"
                       type="number"
                       step="0.1"
                       class="form-control-custom" />
            </div>

            <div class="log-food-actions">
                <button type="submit" class="btn-primary-custom">
                    + Tilføj
                </button>
            </div>

        </form>

    </div>
</section>


