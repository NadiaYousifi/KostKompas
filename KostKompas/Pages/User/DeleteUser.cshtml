@page "{id:int}"
@model KostKompas.Pages.User.DeleteUserModel
@{
}
<section class="delete-page">
    <div class="delete-card">

        <p class="eyebrow">BRUGERE</p>

        <h1>Slet Bruger</h1>

        <p class="delete-text">
            Er du sikker på, at du vil slette Brugeren
            <strong>@Model.User.Name</strong>?
        </p>

        <form method="post" class="delete-actions">
            <button type="submit" class="btn-danger-custom">
                Ja, slet
            </button>

            <a asp-page="/User/GetAllUsers" class="btn-secondary-custom">
                Nej, gå tilbage
            </a>
        </form>

    </div>
</section>