@page
@model KostKompas.Pages.User.DeleteUserModel
@{
}
<h1>Delete Confirmation</h1>
<div class="alert alert-danger">
    <h5>Are you sure you want to delete User - @Model.User.Name</h5>
    <form method="post">
        <button type="submit" class="btn btn-danger">Yes</button>
        <a class="btn btn-primary" asp-page="/User/GetAllUsers">No</a>
    </form>
</div>