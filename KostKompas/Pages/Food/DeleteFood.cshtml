@*Styling af Slet Fødevare*@


<section class="delete-page">
    <div class="delete-card">

        <p class="eyebrow">FØDEVARER</p>

        <h1>Slet fødevare</h1>

        <p class="delete-text">
            Er du sikker på, at du vil slette fødevaren
            <strong>@Model.Food.Name</strong>?
        </p>

        <form method="post" class="delete-actions">
            <button type="submit" class="btn-danger-custom">
                Ja, slet
            </button>

            <a asp-page="/Food/GetAllFoods" class="btn-secondary-custom">
                Nej, gå tilbage
            </a>
        </form>

    </div>
</section>