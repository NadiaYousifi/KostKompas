@page
@model KostKompas.Pages.Chat.AdminChatModel
@{
    ViewData["Title"] = "Admin chat";
}

<div class="chat-page">
    <div class="chat-container">

        <div class="chat-header">
            <div class="coach-avatar">KC</div>
            <div>
                <h2>Admin chat</h2>
                <p>Besvar beskeder fra brugere</p>
            </div>
        </div>

        <div class="chat-messages">
            @foreach (var message in Model.Messages)
            {
                <div class="message @(message.SenderEmail == User.Identity.Name ? "user-message" : "coach-message")">
                    <p>@message.Text</p>
                    <small>
                     @*    Fra: @message.SenderEmail <br /> *@
                        @message.SentAt.ToString("HH:mm")
                    </small>

                    @if (message.SenderEmail != User.Identity.Name)
                    {
                        <form method="post" class="admin-reply-form">
                            <input type="hidden" asp-for="ReceiverEmail" value="@message.SenderEmail" />
                            <input asp-for="ReplyMessage" placeholder="Skriv svar..." />
                            <button type="submit">Svar</button>
                        </form>
                    }
                </div>
            }
        </div>

    </div>
</div>

