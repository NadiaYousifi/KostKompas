@page
@model KostKompas.Pages.Chat.IndexModel
@{
}



<div class="chat-container">

    <div class="chat-header">
        <div class="coach-avatar">KC</div>
        <h2>KostKompas Coaching</h2>
    </div>

    <div class="chat-messages">
        @foreach (var message in Model.Messages)
        {
            <div class="message @(message.IsFromUser ? "user-message" : "coach-message")">
                <p>@message.Text</p>
                <small>@message.SentAt.ToString("HH:mm")</small>
            </div>
        }
    </div>

    <form method="post" class="chat-input">
        <input asp-for="NewMessage" placeholder="Skriv her..." />
        <button type="submit">Send</button>
    </form>

</div>

<style>
    .chat-container {
        max-width: 430px;
        margin: 20px auto;
        background: #d9d9d9;
        min-height: 700px;
        display: flex;
        flex-direction: column;
        border-radius: 20px;
        overflow: hidden;
    }

    .chat-header {
        display: flex;
        align-items: center;
        gap: 12px;
        background: #eeeeee;
        padding: 18px;
    }

    .coach-avatar {
        width: 45px;
        height: 45px;
        border-radius: 50%;
        background: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
    }

    .chat-header h2 {
        font-size: 22px;
        margin: 0;
    }

    .chat-messages {
        flex: 1;
        padding: 16px;
    }

    .message {
        padding: 12px 16px;
        border-radius: 18px;
        margin-bottom: 12px;
        max-width: 80%;
        word-wrap: break-word;
    }

    .coach-message {
        background: white;
        margin-right: auto;
    }

    .user-message {
        background: #b9f4c9;
        margin-left: auto;
    }

    .message p {
        margin: 0;
    }

    .message small {
        display: block;
        margin-top: 5px;
        color: gray;
        font-size: 12px;
    }

    .chat-input {
        display: flex;
        gap: 8px;
        padding: 12px;
        background: white;
    }

    .chat-input input {
        flex: 1;
        border-radius: 20px;
        border: 1px solid #ccc;
        padding: 10px 15px;
    }

    .chat-input button {
        border: none;
        background: #198754;
        color: white;
        border-radius: 20px;
        padding: 10px 18px;
    }
</style>
