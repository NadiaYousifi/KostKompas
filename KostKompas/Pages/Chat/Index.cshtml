@page
@model KostKompas.Pages.Chat.IndexModel
@{
    ViewData["Title"] = "Chat";
}

<div class="chat-page">
    <div class="chat-container">

        <div class="chat-header">
            <div class="coach-avatar">KC</div>
            <div>
                <h2>KostKompas Coaching</h2>
                <p>Her kan du skrive med din coach</p>
            </div>
        </div>

        <div class="chat-messages">
            @foreach (var message in Model.Messages)
            {
                <div class="message @(message.SenderEmail == User.Identity.Name ? "user-message" : "coach-message")">
                    <p>@message.Text</p>
                    <small>
                       @*  @(message.SenderEmail == User.Identity.Name ? "Dig" : "Coach") *@
                        · @message.SentAt.ToString("HH:mm")
                    </small>
                </div>
            }
        </div>

        <form method="post" class="chat-input">
            <input asp-for="NewMessage" placeholder="Skriv her..." />
            <button type="submit">Send</button>
        </form>

    </div>
</div>

<style>
    .chat-page {
        padding: 40px 0 70px;
    }

    .chat-container {
        max-width: 720px;
        margin: 0 auto;
        background: #f4f7f4;
        min-height: 700px;
        display: flex;
        flex-direction: column;
        border-radius: 30px;
        overflow: hidden;
        box-shadow: 0 14px 36px rgba(47, 47, 47, 0.10);
    }

    .chat-header {
        display: flex;
        align-items: center;
        gap: 16px;
        background: linear-gradient(to right, #dff3ee, #f7f3ea);
        padding: 24px 28px;
    }

    .coach-avatar {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background: white;
        color: #4E8F4A;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 20px;
        box-shadow: 0 4px 12px rgba(47, 47, 47, 0.08);
    }

    .chat-header h2 {
        font-size: 1.6rem;
        font-weight: 800;
        margin: 0;
        color: #2F2F2F;
    }

    .chat-header p {
        margin: 4px 0 0;
        color: #6B6B6B;
    }

    .chat-messages {
        flex: 1;
        padding: 24px;
        background: #eef3ef;
    }

    .message {
        padding: 14px 18px;
        border-radius: 22px;
        margin-bottom: 14px;
        max-width: 78%;
        word-wrap: break-word;
        line-height: 1.5;
        box-shadow: 0 4px 14px rgba(47, 47, 47, 0.05);
    }

    .coach-message {
        background: white;
        margin-right: auto;
        border-bottom-left-radius: 8px;
    }

    .user-message {
        background: #b9f4c9;
        margin-left: auto;
        border-bottom-right-radius: 8px;
    }

    .message p {
        margin: 0;
        color: #2F2F2F;
    }

    .message small {
        display: block;
        margin-top: 6px;
        color: #6B6B6B;
        font-size: 12px;
    }

    .chat-input {
        display: flex;
        gap: 10px;
        padding: 18px;
        background: white;
        border-top: 1px solid #e4e4e4;
    }

        .chat-input input {
            flex: 1;
            border-radius: 999px;
            border: 1px solid #d8ddd8;
            background: #f7f7f7;
            padding: 13px 18px;
        }

        .chat-input button {
            border: none;
            background: #6FAF5F;
            color: white;
            border-radius: 999px;
            padding: 12px 22px;
            font-weight: 700;
        }

            .chat-input button:hover {
                background: #4E8F4A;
            }
</style>